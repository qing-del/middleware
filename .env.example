# ============================================================
# ServerA 环境变量模板 — Java 主服务
# 复制为 .env 后填入真实值，切勿将 .env 提交到版本控制
# ============================================================

# ---------- Tailscale 组网 ----------
# Tailscale 管理面板 → Settings → Keys → Generate auth key (Reusable)
# 两台服务器可用同一个 Reusable Key
TS_AUTHKEY=tskey-auth-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Tailscale 网络中的主机名 (用于辨识)
TS_HOSTNAME=server-a-middleware

# ---------- MySQL ----------
MYSQL_ROOT_PASSWORD=change_me_mysql_root_pwd
MYSQL_DATABASE=personal_saas
MYSQL_USER=middleware_user
MYSQL_PASSWORD=change_me_mysql_user_pwd

# ---------- Redis ----------
REDIS_PASSWORD=change_me_redis_pwd
REDIS_BIND_ADDRESS=0.0.0.0
REDIS_PORT=6379

# ---------- Spring Boot 回调端口 ----------
BACKEND_BIND_ADDRESS=0.0.0.0

# ---------- Java 应用配置 ----------
JAVA_OPTS=-Xms512m -Xmx1024m

JACOLP_DATASOURCE_HOST=mysql
JACOLP_DATASOURCE_PORT=3306
JACOLP_DATASOURCE_DATABASE=personal_saas
JACOLP_DATASOURCE_USERNAME=middleware_user
JACOLP_DATASOURCE_PASSWORD=change_me_mysql_user_pwd

JACOLP_REDIS_HOST=redis
JACOLP_REDIS_PORT=6379
JACOLP_REDIS_PASSWORD=change_me_redis_pwd

# ---------- 管理员 (Creator) ----------
JACOLP_ADMIN_USERNAME=admin
JACOLP_ADMIN_PASSWORD=change_me_admin_pwd
JACOLP_ADMIN_EMAIL=admin@example.com
JACOLP_DEFAULT_PASSWORD=123456

# ---------- JWT ----------
# 生产环境用 openssl rand -base64 64 生成
JWT_ADMIN_SECRET_KEY=change_me_admin_jwt_secret_key_64chars_min
JWT_ADMIN_TOKEN_NAME=adminToken
JWT_USER_SECRET_KEY=change_me_user_jwt_secret_key_64chars_min
JWT_USER_TOKEN_NAME=userToken
JACOLP_JWT_ACTIVE_SECRET_KEY=change_me_active_secret_key_64chars_min
JACOLP_JWT_ACTIVE_TOKEN_NAME=activeToken

# ---------- 阿里云 OSS ----------
OSS_ACCESS_KEY_ID=change_me_oss_access_key_id
OSS_ACCESS_KEY_SECRET=change_me_oss_access_key_secret
JACOLP_ALIYUN_OSS_ENDPOINT=oss-cn-guangzhou.aliyuncs.com
JACOLP_ALIYUN_OSS_BUCKET_NAME=jacolp-middleware
JACOLP_ALIYUN_OSS_REGION=cn-guangzhou

# ---------- 应用 ----------
# Cloudflare Tunnel 分配的公网域名（Email 等模块会使用）
JACOLP_APP_BASE_URL=https://app.your-domain.com

# ---------- SMTP ----------
JACOLP_MAIL_HOST=smtp.qq.com
JACOLP_MAIL_PORT=465
JACOLP_MAIL_USERNAME=your_email@qq.com
JACOLP_MAIL_PASSWORD=change_me_smtp_auth_code

# ---------- 音频回调 ----------
# 与 ServerB 的 CALLBACK_TOKEN 完全一致
JACOLP_AUDIO_CALLBACK_TOKEN=change_me_callback_token
# 音频回调的域名
VITE_SOURCE_REQUEST_BASE_URL=http://audio.your-domain.com

# ---------- Cloudflare Tunnel ----------
# Cloudflare Zero Trust → Tunnels → Create → 复制 Token
# Public Hostname: app.your-domain.com → http://nginx:80
CLOUDFLARE_TUNNEL_TOKEN=change_me_cloudflare_tunnel_token
