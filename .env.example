# ============================================================
# 环境变量模板 — 复制为 .env 后填入真实值，docker-compose 会自动读取
# WARNING: .env 文件包含敏感信息，请勿提交到 Git！
# ============================================================

# ---------- MySQL ----------
JACOLP_DATASOURCE_HOST=mysql
JACOLP_DATASOURCE_PORT=3306
JACOLP_DATASOURCE_DATABASE=personal_saas
JACOLP_DATASOURCE_USERNAME=root
JACOLP_DATASOURCE_PASSWORD=your_mysql_password

# ---------- Redis ----------
JACOLP_REDIS_HOST=redis
JACOLP_REDIS_PORT=6379

# ---------- 管理员初始账号（服务器启动时自动创建/覆盖）----------
JACOLP_ADMIN_USERNAME=admin
JACOLP_ADMIN_PASSWORD=your_admin_password

# ---------- JWT 密钥（请替换为随机字符串，生产环境务必修改）----------
JWT_ADMIN_SECRET_KEY=your-admin-secret-key
JWT_ADMIN_TOKEN_NAME=adminToken
JWT_USER_SECRET_KEY=your-user-secret-key
JWT_USER_TOKEN_NAME=userToken
JACOLP_JWT_ACTIVE_SECRET_KEY=your-active-secret-key
JACOLP_JWT_ACTIVE_TOKEN_NAME=activeToken

# ---------- 阿里云 OSS（不使用可注释掉，并在 application-docker.yml 中设 enabled: false）----------
OSS_ACCESS_KEY_ID=your_aliyun_access_key_id
OSS_ACCESS_KEY_SECRET=your_aliyun_access_key_secret
JACOLP_ALIYUN_OSS_ENDPOINT=oss-cn-guangzhou.aliyuncs.com
JACOLP_ALIYUN_OSS_BUCKET_NAME=your-bucket-name
JACOLP_ALIYUN_OSS_REGION=cn-guangzhou

# ---------- Cloudflare R2（可选，如不使用忽略即可）----------
# CLOUDFLARE_ACCOUNT_ID=your_account_id

# ---------- MySQL root 密码（docker-compose 内部使用）----------
MYSQL_ROOT_PASSWORD=your_mysql_password

# ---------- 部署项目访问地址 ----------
JACOLP_BASE_URL=http://your-domain.com